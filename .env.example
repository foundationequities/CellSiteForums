# ForumAgent environment configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets.

# Master key for Fernet credential encryption (Phase 2).
# Generate one with:  python -m app.main --generate-key
# Save it somewhere safe — losing it means re-entering every stored credential.
FORUMAGENT_KEY=

# Optional. If set, posts scoring >= MEDIUM are classified by Claude and
# AI reply drafting is enabled. The app runs fully without this
# (keyword scoring + manual drafting fallback).
ANTHROPIC_API_KEY=

# Optional overrides (defaults shown).
# FORUMAGENT_HOST=127.0.0.1
# FORUMAGENT_PORT=8420
